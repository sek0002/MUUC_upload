[Unit]
Description=MUUC Upload Portal
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/muuc-upload-portal
EnvironmentFile=/opt/muuc-upload-portal/.env
ExecStart=/opt/muuc-upload-portal/.venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
